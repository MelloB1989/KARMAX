# Anthropic-compatible gateway (kiro-gateway). Serves the primary model and all
# fallbacks: claude-opus-4.6, claude-sonnet-4.6, deepseek-3.2.
ANTHROPIC_BASE_URL=http://localhost:9000
ANTHROPIC_AUTH_TOKEN=your_auth_token_here
ANTHROPIC_API_KEY=your_api_key_here

# WhatsApp chat Nexus messages for briefings/alerts (your number or a chat name).
WHATSAPP_TARGET=

# ntfy push to your phone. Pick a hard-to-guess topic and subscribe to it in the
# ntfy iOS app. Server defaults to https://ntfy.sh.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# Optional: require an HMAC signature on the /trigger webhook.
KARMAX_WEBHOOK_SECRET=

# Bearer token the KARMAX phone app uses to authenticate to the HTTP API (:9091).
# Generate a long random string and set the same value in the app.
KARMAX_API_TOKEN=

# Optional: enable the Discord channel in karmax.yaml.
# DISCORD_BOT_TOKEN=

# ---- Host paths (all optional) --------------------------------------------
# Every external binary/dir KARMAX uses resolves automatically (PATH, then
# well-known locations under $HOME). Set these only to override.
# KARMAX_WACLI_PATH=      # wacli binary (default: PATH, then ~/code/wacli/wacli)
# KARMAX_GWS_PATH=        # gws binary (default: PATH, then ~/.hermes/node/bin/gws, ~/.local/bin/gws)
# KARMAX_BIN=             # karmax CLI given to delegated harnesses (default: the running executable)
# KARMAX_WORKDIR=         # default working dir for delegated coding tasks (default: $HOME)
# KARMAX_WACLI_API_URL=   # wacli HTTP API (default: http://127.0.0.1:8765)
# KARMAX_API_URL=         # KARMAX API base the CLI talks to (default: http://localhost:<api.port>)

# ---- Loop configuration ----------------------------------------------------
# Loops read config as KARMAX_LOOP_<LOOP_NAME>_<KEY> (loop name upper-snaked).
# All optional — a loop falls back to sensible defaults when unset.

# wa-monitor — the proactive WhatsApp proxy.
# How KARMAX refers to you in the assistant "away" note it sends when it flags a
# message instead of answering (falls back to a generic phrase).
# KARMAX_LOOP_WA_MONITOR_OPERATOR_NAME=Kartik
#
# Trusted working groups (comma-separated JIDs) where KARMAX replies AS you
# without needing an @-mention — e.g. a client project group. Routine acks go
# out in your voice; real decisions still become approvals. Other groups stay
# conservative.
# KARMAX_LOOP_WA_MONITOR_REPLY_GROUPS=1203634...@g.us,1203634...@g.us
#
# Optional fallback list of KARMAX's own number/LID digits used to detect "the
# bot was @-mentioned". Normally unnecessary: wacli reports mentions_me from its
# own identity, so this only helps if that signal is missing.
# KARMAX_LOOP_WA_MONITOR_BOT_MENTIONS=91XXXXXXXXXX,2298967XXXXXXXX
#
# How many @-mentions in one message make it an "@all"/"@everyone" blast rather
# than someone addressing KARMAX. Such blasts are ignored in groups you don't
# track. Default 5.
# KARMAX_LOOP_WA_MONITOR_MASS_MENTION_MIN=5
