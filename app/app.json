{
  "expo": {
    "name": "KARMAX",
    "slug": "karmax",
    "owner": "mellob",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "karmax",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0d12",
    "ios": {
      "bundleIdentifier": "in.ghmev.karmax",
      "supportsTablet": true,
      "infoPlist": {
        "NSCalendarsUsageDescription": "KARMAX adds your events and meetings to your calendar.",
        "NSRemindersFullAccessUsageDescription": "KARMAX sets reminders for you.",
        "NSLocalNetworkUsageDescription": "KARMAX connects to your KARMAX daemon on your local network or Tailscale.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "UIBackgroundModes": [
          "fetch",
          "processing",
          "remote-notification"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.expo.modules.backgroundtask.processing"
        ]
      }
    },
    "android": {
      "package": "in.ghmev.karmax",
      "adaptiveIcon": {
        "backgroundColor": "#0a0d12",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0d12",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "expo-secure-store",
      [
        "expo-calendar",
        {
          "calendarPermission": "KARMAX adds your events and meetings to your calendar.",
          "remindersPermission": "KARMAX sets reminders for you."
        }
      ],
      "expo-notifications",
      "expo-background-task",
      [
        "expo-contacts",
        {
          "contactsPermission": "KARMAX resolves and creates contacts so people show up by name, not just a number."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "KARMAX uses the microphone so you can talk to it instead of typing.",
          "speechRecognitionPermission": "KARMAX transcribes your speech into commands for the agent."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7741eced-b3f7-4608-a805-bcf90ea7033b"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7741eced-b3f7-4608-a805-bcf90ea7033b"
    }
  }
}
