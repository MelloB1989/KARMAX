# KARMAX Configuration Example
# Copy this file to karmax.yaml and fill in your values.

karmax:
  version: "2"
  data_dir: "~/.karmax"        # Where KARMAX stores its database, memory, and logs
  log_level: "info"            # Options: debug, info, warn, error
  log_format: "pretty"         # Options: pretty, json

# Webhooks — HTTP server for external trigger integrations
webhooks:
  enabled: true
  port: 9090
  host: "0.0.0.0"
  routes: []
  # Example route:
  # - path: "/github"
  #   method: "POST"
  #   agent_id: "karmax-agent"
  #   bus_event: "webhook.github"
  #   secret: "YOUR_WEBHOOK_SECRET"
  #   signature_header: "X-Hub-Signature-256"

# AI provider configuration
ai:
  default_provider: "anthropic"
  default_model: "claude-opus-4.6"
  providers:
    anthropic:
      api_key: "YOUR_ANTHROPIC_API_KEY"
      base_url: ""             # Leave empty for default, or set a proxy URL
      auth_token: ""           # Optional auth token for proxy endpoints
    openai:
      api_key: "YOUR_OPENAI_API_KEY"
    # All models below (primary + fallbacks: claude-opus-4.6, claude-sonnet-4.6,
    # deepseek-3.2) route through the local Anthropic-compatible gateway above,
    # so no separate provider keys are required.

# MCP (Model Context Protocol) servers — external tool providers
mcps: []
# Example:
# - id: "filesystem"
#   command: "npx"
#   args: ["-y", "@anthropic/mcp-server-filesystem", "/home/user"]

# Communication channels — how the agent talks to you
comms:
  channels:
    - id: "discord-main"
      type: "discord"
      agent_id: "karmax-agent"
      token: "YOUR_DISCORD_BOT_TOKEN"
    - id: "whatsapp-main"
      type: "whatsapp"
      agent_id: "karmax-agent"
      token: ""
      settings:
        wacli_path: "/path/to/wacli"          # Path to wacli binary
        target_chat: "YOUR_PHONE_NUMBER"       # Target WhatsApp number (e.g., "9198XXXXXXXX")

# Agent definitions
agents:
  - id: "karmax-agent"
    name: "KARMAX Personal Agent"
    description: "Autonomous personal AI agent with full system access and decision-making capability"
    system_prompt: |
      You are KARMAX, an autonomous AI agent. You have complete context about your operator and their projects.

      ## Your Capabilities
      - Full shell access to the machine
      - File read/write access to all projects
      - HTTP/API call capability
      - Memory retrieval from your knowledge base (use memory.retrieve tool)
      - Memory ingestion to save important information (use memory.ingest tool)
      - Ability to delegate coding tasks to Claude Code or Codex (use claude_code.call or codex.call tools)
      - Communication via Discord (use comms.send tool)
      - Permission escalation via alternate channels (use comms.escalate tool)

      ## Decision-Making Rules
      1. For routine tasks (reading files, searching, analyzing, responding to questions): Act autonomously
      2. For moderate actions (writing files, making API calls, running safe commands): Act and inform via comms
      3. For dangerous actions (deleting files, force-pushing, modifying production, spending money): ALWAYS ask for permission via comms BEFORE acting
      4. When uncertain about anything: Ask via comms

      ## Communication
      When you need to communicate, use the comms.send tool with the appropriate channel_id.
      When messaged via Discord or WhatsApp, respond to the original channel and target captured in the incoming event.
      Respect channels marked DND. For dangerous actions, use comms.escalate before acting.

      ## Coding Tasks
      When delegating coding work:
      - Use claude_code.call for complex, multi-file tasks
      - Use codex.call for simpler, focused coding tasks
      - Always provide clear, detailed prompts
      - Track session IDs to continue related work

      ## Google Workspace
      You can manage Google Workspace: Calendar, Drive, Gmail, Sheets, Docs using the google_workspace tool.
      Use google_workspace.schema to look up API parameters before making calls.
      Common operations:
      - Calendar: list events, create events, update events
      - Drive: list files, create folders, upload files
      - Gmail: list messages, send emails
      - Sheets: read/write spreadsheets
      - Docs: create/read documents

      ## WhatsApp Communication
      You can also communicate via WhatsApp using channel_id "whatsapp-main".
      Use this for urgent messages or when Discord is not suitable.

    model: "claude-opus-4.6"            # Primary model
    provider: "anthropic"               # Primary provider

    temperature: 0.7
    max_tokens: 8192

    # Sub-models for memory retrieval and history compaction
    memory_model:
      model: "claude-sonnet-4.6"
      provider: "anthropic"
    summary_model:
      model: "claude-sonnet-4.6"
      provider: "anthropic"

    # Fallback models — tried in order when the primary model fails.
    # All route through the same local gateway under the "anthropic" provider.
    fallback_models:
      - provider: "anthropic"
        model: "claude-sonnet-4.6"
      - provider: "anthropic"
        model: "deepseek-3.2"

    # Compaction settings — summarize chat history when token count exceeds threshold
    compaction_threshold: 128000         # Tokens before compaction triggers
    compaction_keep_recent: 20           # Messages to keep verbatim after compaction

    # Tools available to this agent
    tools:
      - shell.exec
      - file.read
      - file.write
      - file.list
      - http.request
      - email.send
      - notify.send
      - memory.ingest
      - claude_code.call
      - codex.call
      - comms.send
      - google_workspace
      - google_workspace.schema

    # Memory configuration
    memory:
      enabled: true
      namespace: "karmax-agent"
      max_entries: 1000

    # Restart policy: "always", "on-failure", "never"
    restart_policy: "always"
    max_restarts: 10

    # Health check — periodic ping to ensure the agent is responsive
    health_check:
      interval_seconds: 60
      ping_prompt: "ping"

    # Triggers — how this agent gets activated
    triggers:
      run_on_start: true
      # webhooks: ["github-push"]
      # schedules:
      #   - cron: "0 9 * * *"
      #     payload:
      #       task: "daily_review"

# Loops — declarative recurring triggers. Each fires its prompt to the agent on
# its schedule (cron "sec min hour dom mon dow", or every: "2h"/"30m") and the
# agent decides what to do.
loops:
  # A "harness" loop runs its prompt DIRECTLY through a coding harness (e.g.
  # claude_code) and ingests the output to memory — bypassing the main model, so
  # web-research loops keep working even when the main model is rate-limited.
  - name: "tech-news"
    cron: "0 0 9 * * *"           # 09:00 daily
    harness: "claude_code"        # run via the Claude CLI (has web access), independent of the main model
    prompt: >-
      Search the web for the latest AI/tech/security news from the last 24-48h. Output a clean
      digest of 5-8 fresh, relevant items (one line + source each). Your output is saved to memory.

  # A normal loop fires the prompt to the agent, which uses its tools. Deliver
  # proactive updates to the phone app with app.push (lands in the app's
  # notification feed AND sends a push); use comms.send for WhatsApp/Discord.
  - name: "daily-briefing"
    cron: "0 30 8 * * *"          # 08:30 daily
    prompt: >-
      Compile a short morning briefing (top tech news from memory, today's calendar/reminders,
      open coding sessions, anything pending from WhatsApp). You MUST deliver it by calling the
      app.push tool (title "Morning briefing") — that is the required final step.
